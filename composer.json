{
    "name": "wp-gj-builder/wp-gj-builder",
    "description": "WP-Builder: конструктор страниц WordPress на GrapesJS",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "WPGJBuilder\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPGJBuilder\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress-Extra includes/",
        "analyse": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
