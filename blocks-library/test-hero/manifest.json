{
  "id": "test-hero",
  "schema_version": 1,
  "section_type": "hero",
  "tags": ["landing", "test-fixture"],
  "purpose": "Тестовая фикстура для проверки ManifestValidator (Phase 1) — первый экран с заголовком, подзаголовком, кнопкой, изображением и списком карточек.",
  "slots": [
