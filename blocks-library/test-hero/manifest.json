      "min_items": 3,
      "max_items": 6,
      "item_schema": {
        "icon": { "type": "icon" },
        "title": { "type": "string", "max_length": 40 },
        "text": { "type": "string", "max_length": 120 }
      }
    }
  ],
  "context": {
    "recommended_after": [],
    "allow_repeat": false,
    "niches": []
  },
  "requirements": {
    "dynamic_tags": ["post.title"],
    "assets": { "js": [], "css": [] }
  },
  "style_whitelist": ["background-color", "color", "padding", "padding-top", "padding-bottom", "text-align"],
  "layout_variants": ["default", "image-left"]
}
