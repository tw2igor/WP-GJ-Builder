{
  "id": "test-gallery",
  "schema_version": 1,
  "section_type": "gallery",
  "tags": ["landing"],
  "purpose": "Галерея изображений с подписями — сетка фотографий работ/продукции.",
  "slots": [
    { "key": "title", "type": "string", "max_length": 60 },
    {
      "key": "items",
      "type": "array",
      "min_items": 2,
      "max_items": 12,
      "item_schema": {
        "image": { "type": "image" },
        "caption": { "type": "string", "max_length": 60 }
      }
    }
  ],
  "context": { "recommended_after": ["features"], "allow_repeat": false, "niches": [] },
  "requirements": { "dynamic_tags": [], "assets": { "js": [], "css": [] } },
  "style_whitelist": ["background-color", "color", "padding", "padding-top", "padding-bottom", "text-align"],
  "layout_variants": ["default"]
}
