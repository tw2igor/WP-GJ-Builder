{
  "id": "footer-simple",
  "schema_version": 1,
  "section_type": "footer",
  "tags": ["footer", "navigation"],
  "purpose": "Простой подвал сайта: название, короткий слоган, строка ссылок и копирайт — для использования как «Часть сайта» типа Подвал.",
  "slots": [
    { "key": "site_name", "type": "string", "max_length": 40 },
    { "key": "tagline", "type": "string", "max_length": 120 },
    {
      "key": "nav_items",
      "type": "array",
      "min_items": 1,
      "max_items": 6,
      "item_schema": {
        "label": { "type": "string", "max_length": 30 },
        "link": { "type": "link" }
      }
    },
    { "key": "copyright", "type": "string", "max_length": 100 }
  ],
  "context": { "recommended_after": [], "allow_repeat": false, "niches": [] },
  "requirements": { "dynamic_tags": ["site.title"], "assets": { "js": [], "css": [] } },
  "style_whitelist": ["background-color", "color", "padding", "padding-top", "padding-bottom"],
  "layout_variants": ["default"]
}
