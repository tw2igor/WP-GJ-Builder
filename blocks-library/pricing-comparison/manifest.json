{
  "id": "pricing-comparison",
  "schema_version": 1,
  "section_type": "pricing",
  "tags": ["landing", "pricing", "comparison"],
  "purpose": "Сравнение двух тарифов бок о бок с выделенным «рекомендуемым» планом — вариант для случаев, когда тарифов немного и их удобно сравнивать напрямую.",
  "slots": [
    { "key": "title", "type": "string", "max_length": 60 },
    {
      "key": "plans",
      "type": "array",
      "min_items": 2,
      "max_items": 3,
      "item_schema": {
        "name": { "type": "string", "max_length": 30 },
        "price": { "type": "string", "max_length": 20 },
        "features": { "type": "richtext", "max_length": 300 },
        "cta_label": { "type": "string", "max_length": 25 },
        "cta_link": { "type": "link" }
      }
    }
  ],
  "context": { "recommended_after": ["features"], "allow_repeat": false, "niches": [] },
  "requirements": { "dynamic_tags": [], "assets": { "js": [], "css": [] } },
  "style_whitelist": ["background-color", "color", "padding", "padding-top", "padding-bottom", "text-align"],
  "layout_variants": ["default"]
}
