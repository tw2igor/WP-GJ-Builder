{
  "id": "about-split",
  "schema_version": 1,
  "section_type": "about",
  "tags": ["landing", "about", "story"],
  "purpose": "О компании: фото/иллюстрация с одной стороны, заголовок и текст истории — с другой. Классический раздел «О нас» для лендинга.",
  "slots": [
