    { "key": "body", "type": "richtext", "max_length": 600 },
    {
      "key": "image",
      "type": "image",
      "orientation": "portrait",
      "min_width": 800
    },
    { "key": "cta_label", "type": "string", "max_length": 25 },
    { "key": "cta_link", "type": "link" }
  ],
  "context": { "recommended_after": ["hero"], "allow_repeat": false, "niches": [] },
  "requirements": { "dynamic_tags": [], "assets": { "js": [], "css": [] } },
  "style_whitelist": ["background-color", "color", "padding", "padding-top", "padding-bottom"],
  "layout_variants": ["default", "image-right"]
}
