{
  "id": "stats-counters",
  "schema_version": 1,
  "section_type": "stats",
  "tags": ["landing", "stats", "numbers", "social-proof"],
  "purpose": "Цифры и факты: ряд крупных чисел с подписью — количество клиентов, лет на рынке, выполненных проектов и т.п.",
  "slots": [
    { "key": "title", "type": "string", "max_length": 60 },
